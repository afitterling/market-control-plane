{
  "name": "market-control-plane",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "license": "AGPL-3.0-or-later",
  "author": "Alex Fitterling",
  "scripts": {
    "setup": "npx sst install",
    "secrets:load": "npx sst secret load .env",
    "dev": "npm run secrets:load && npx sst dev",
    "deploy": "npm run secrets:load && npx sst deploy",
    "logs": "npx sst logs --stage dev",
    "remove": "npx sst remove",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-apigatewaymanagementapi": "^3.808.0",
    "@aws-sdk/client-dynamodb": "^3.808.0",
    "@aws-sdk/client-kinesis": "^3.808.0",
    "@aws-sdk/client-lambda": "^3.1045.0",
    "@aws-sdk/lib-dynamodb": "^3.808.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.147",
    "@types/node": "^22.15.17",
    "sst": "^3.19.3",
    "typescript": "^5.8.3"
  }
}
