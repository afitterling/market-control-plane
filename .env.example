# Shared bearer token required by every API route.
# Loaded by sst.config.ts via process.env and exposed to every Lambda.
API_BEARER_TOKEN=replace-me

# Financial Modeling Prep API key.
# Used by the ProcessStock function (earnings backfill) and the PullPrices cron
# (30s real-time quote refresh).
FMP_API_KEY=replace-me

# Separate token required by POST /pulse/refresh (X-Refresh-Token header).
# Decoupled from API_BEARER_TOKEN so the force-trigger isn't auto-exposed if
# the regular bearer leaks. Generate with: openssl rand -hex 32
PULSE_REFRESH_TOKEN=replace-me

# no cognito idendity pool linked yet (see my other projects)
API_BEARER_TOKEN=replace-me
